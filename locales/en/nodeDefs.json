        "random_bool": "Random Boolean"
      }},
      "min_val": { "name": "Min", "tooltip": "Lower bound for int/float mode" },
      "max_val": { "name": "Max", "tooltip": "Upper bound for int/float mode" }
    },
    "outputs": { "0": { "name": "Random", "tooltip": "Generated value" } }
  },
