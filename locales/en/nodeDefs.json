      "2": { "name": "Total", "tooltip": "Total repetitions" },
      "3": { "name": "Remaining", "tooltip": "Remaining count" }
    }
  },
  "Logic_Random": {
    "display_name": "🎲 Random Tool",
    "description": "Generate random integer, float, seed, or boolean.",
    "inputs": {
      "mode": { "name": "Mode", "tooltip": "Random type", "options": {
