      "3": { "name": "Frame Rate", "tooltip": "FPS" },
      "4": { "name": "Frame Count", "tooltip": "Extracted frames" },
      "5": { "name": "Width", "tooltip": "Video width" },
      "6": { "name": "Height", "tooltip": "Video height" }
