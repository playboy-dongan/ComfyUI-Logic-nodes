      "B": { "name": "B", "tooltip": "Variable B" },
      "C": { "name": "C", "tooltip": "Variable C" },
      "D": { "name": "D", "tooltip": "Variable D" }
    },
    "outputs": {
      "0": { "name": "Float", "tooltip": "FLOAT result" },
      "1": { "name": "Integer", "tooltip": "INT result" },
      "2": { "name": "Boolean", "tooltip": "BOOLEAN result" }
    }
