{
  "Logic_Blocker": {
    "display_name": "🚧 Blocker",
    "description": "Pass or block data based on a boolean switch.",
    "inputs": {
      "any": { "name": "Any", "tooltip": "Input of any type" },
      "enable": { "name": "Enable", "tooltip": "Pass/Block" }
    },
    "outputs": { "0": { "name": "Any", "tooltip": "Pass-through or blocked" } }
  },
  "Logic_PreviewType": {
    "display_name": "👁️ Preview Type",
    "description": "Display the type name and details of input data.",
    "inputs": { "any": { "name": "Any", "tooltip": "Input of any type" } }
  },
  "Logic_Judge": {
    "display_name": "⚖️ Judge",
    "description": "Conditional comparison of two values, outputs boolean.",
    "inputs": {
      "any_a": { "name": "Any A", "tooltip": "First value to compare" },
      "condition": { "name": "Condition", "tooltip": "Comparison condition", "options": {
        "A == B": "A == B", "A != B": "A != B", "A > B": "A > B", "A < B": "A < B", "A >= B": "A >= B", "A <= B": "A <= B",
        "A contains B": "A contains B", "A is empty": "A is empty", "A is not empty": "A is not empty", "A is true": "A is true", "A is false": "A is false",
        "length == B": "length == B", "length > B": "length > B", "length < B": "length < B"
      }},
      "any_b": { "name": "Any B", "tooltip": "Second value (optional)" }
    },
    "outputs": { "0": { "name": "Result", "tooltip": "Boolean result" } }
  },
  "Logic_Switch": {
    "display_name": "🔀 Switch",
    "description": "Select one of two inputs based on a boolean value.",
    "inputs": {
      "true_val": { "name": "True", "tooltip": "Output when condition is true" },
      "false_val": { "name": "False", "tooltip": "Output when condition is false" },
      "condition": { "name": "Condition", "tooltip": "Boolean condition" }
    },
    "outputs": { "0": { "name": "Output", "tooltip": "Selected input" } }
  },
  "Logic_Switcher": {
    "display_name": "🎚️ Switcher",
    "description": "Select one output from multiple inputs by index.",
    "inputs": {
      "select": { "name": "Select", "tooltip": "Index of output port" },
      "any1": { "name": "Any 1", "tooltip": "Input 1" },
      "any2": { "name": "Any 2", "tooltip": "Input 2" }
    },
    "outputs": { "0": { "name": "Output", "tooltip": "Selected input" } }
  },
  "Logic_UniversalPreview": {
    "display_name": "🖥️ Universal Preview",
    "description": "Preview almost all ComfyUI data formats.",
    "inputs": { "any": { "name": "Any", "tooltip": "Input of any type" } }
  },
  "Logic_BatchCombiner": {
    "display_name": "📦 Batch Combiner",
